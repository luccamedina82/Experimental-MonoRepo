generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  sessions      Session[]
  @@map("users")
}


model Session {
  id          String   @id @default(cuid())
  user_id     String
  hashed_rt   String
  device_info String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}